DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=capstone

# LLM_PROVIDER can be: gemini, anthropic, openai
LLM_PROVIDER=gemini
# LLM MODEL can be: gemini-3.1-pro, claude-sonnet-4-6, gpt-4.0-turbo
LLM_MODEL=gemini-3.1-pro
GOOGLE_API_KEY=your_google_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# RAG embeddings use GOOGLE_API_KEY and keep 1536 dimensions for the pgvector schema.
RAG_EMBEDDING_MODEL=gemini-embedding-001

# Optional Elasticsearch MCP enrichment for the incident analyzer.
# Use http://elasticsearch-mcp:8080/mcp if the backend runs inside the elk-stack Docker network.
ELASTICSEARCH_MCP_ENABLED=false
ELASTICSEARCH_MCP_URL=http://localhost:8085/mcp
ELASTICSEARCH_MCP_ALLOWED_INDEX_PATTERN=logstash-*
ELASTICSEARCH_MCP_SERVICE_FIELD=fields.service
ELASTICSEARCH_MCP_SERVICE_VALUE=dvwa-apache
ELASTICSEARCH_MCP_MAX_RESULTS=20
ELASTICSEARCH_MCP_MAX_WINDOW_MINUTES=30
ELASTICSEARCH_MCP_REQUEST_TIMEOUT_SECONDS=10
